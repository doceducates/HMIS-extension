    "crx": "^5.0.1",
    "typescript": "^5.0.2",
    "vite": "^5.2.0",
    "vite-plugin-static-copy": "^1.0.6"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
